# Copy to .env and fill in values. .env is gitignored.
# Get a key: https://ollama.com/settings/keys

OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma4:31b-cloud
PORT=8080
HELIOS_BASE_URL=http://127.0.0.1:8080

# Bind address (default loopback â€” do NOT expose chat/C2 on a LAN)
HELIOS_BIND=127.0.0.1

# Optional shared-lab / non-loopback auth (see docs/post-landing-hardening-design.md Â§A2)
# Unset = T0 recommended: open APIs on loopback Host only
# Set = T1/T2: Bearer required on /api/chat and /api/agent/*
# HELIOS_API_TOKEN=your_local_token_here

# Firebase web app (client config)
# Values appear in the browser — lock data with Firestore/RTDB/Storage Security Rules.
# FIREBASE_API_KEY is NOT a secret like a server key; still keep .env out of git.
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=1:xxx:web:yyy
