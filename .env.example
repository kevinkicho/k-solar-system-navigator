# Copy to .env and fill in values. .env is gitignored.
# Get a key: https://ollama.com/settings/keys

OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma4:31b-cloud
PORT=8080
HELIOS_BASE_URL=http://127.0.0.1:8080

# Bind address (default loopback — do NOT expose chat/C2 on a LAN)
HELIOS_BIND=127.0.0.1

# Optional shared-lab / non-loopback auth (see docs/post-landing-hardening-design.md §A2)
# Unset = T0 recommended: open APIs on loopback Host only
# Set = T1/T2: Bearer required on /api/chat and /api/agent/*
# HELIOS_API_TOKEN=your_local_token_here
