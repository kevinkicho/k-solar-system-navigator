rules_version = '2';

// HELIOS cloud plans — owner-only under users/{uid}/**
// Web client config is public; these rules are the real access control.
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Per-user tree (plans, future prefs, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Optional user profile doc at users/{uid}
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
